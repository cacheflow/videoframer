{
  "name": "framewise",
  "version": "1.0.0",
  "description": "Analyze videos with multimodal AI, one frame at a time.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "npm test && npm run build",
    "secrets:scan": "gitleaks git --redact --verbose",
    "secrets:scan:staged": "gitleaks git --staged --redact --verbose",
    "test": "npm run build && node --test",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/genai": "^2.12.0",
    "dotenv": "^17.4.2",
    "ffmpeg": "^0.0.4",
    "openai": "^6.47.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/ffmpeg": "^1.0.7",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
